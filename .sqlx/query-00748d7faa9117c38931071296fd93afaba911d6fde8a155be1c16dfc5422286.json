  "query": "\n        SELECT a.id, a.email, a.plan, COALESCE(ad.data, '{}'::jsonb) as \"data!\"\n        FROM accounts a\n        LEFT JOIN account_data ad ON a.id = ad.account_id\n        WHERE a.id = $1\n        ",

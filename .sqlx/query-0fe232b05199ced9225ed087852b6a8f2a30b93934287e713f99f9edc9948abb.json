  "query": "\n        SELECT prt.id, prt.account_id, prt.expires_at, prt.used_at, a.email\n        FROM password_reset_tokens prt\n        JOIN accounts a ON a.id = prt.account_id\n        WHERE prt.token_hash = $1\n        ",

{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id, email, role, permissions, status,\n            invited_at, accepted_at, last_access_at\n        FROM website_administrators\n        WHERE website_id = $1\n        ORDER BY \n            CASE role \n                WHEN 'owner' THEN 0 \n                WHEN 'admin' THEN 1 \n                WHEN 'editor' THEN 2 \n                ELSE 3 \n            END,\n            invited_at ASC\n        ",

{
  "name": "asap-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "ASAP Platform - Portfolio & Website Builder",
  "type": "module",
  "scripts": {
    "dev": "make dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @asap/web build",
    "build:sites": "pnpm --filter @asap/sites build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}

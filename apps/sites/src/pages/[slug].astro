---
/**
 * Dynamic Public Page - Renders any published website by slug
 * 100% SSR for optimal SEO - no client-side JavaScript needed
 * Route: /{slug}
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionsRenderer from '@/components/rendering/SectionsRenderer.astro';
import PageNavigation from '@/components/site/PageNavigation.astro';
import { buildSeo, getSiteRenderPayload, resolveSitePage } from '@/lib/site-data';

// Get slug from URL and normalize to lowercase for case-insensitive matching
const { slug: rawSlug } = Astro.params;
const slug = String(rawSlug || '').toLowerCase();

if (!slug) {
  return Astro.redirect('/');
}

const payload = await getSiteRenderPayload(slug);

if (!payload) {
  return Astro.redirect('/404');
}

const { website, theme, tokens } = payload;

if (website.status !== 'published') {
  return Astro.redirect('/404');
}

const page = resolveSitePage(payload);

if (!page) {
  return Astro.redirect('/404');
}

const seo = buildSeo(payload, page, slug);
const showNavigation = payload.pages.length > 1;
---

<BaseLayout
  seo={seo}
  theme={theme}
  tokens={tokens}
  favicon={website.metadata?.favicon}
  fontFamily={tokens?.typography.bodyFamily ?? theme?.fontFamily}
>
  {showNavigation && (
    <PageNavigation
      pages={payload.pages}
      activeSlug={page.slug}
      siteSlug={slug}
      siteTitle={website.title}
    />
  )}

  <div class:list={[showNavigation && 'pt-20']}>
    {page.sections.length === 0 ? (
      <!-- Default hero when no elements configured -->
      <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
        <div class="text-center px-6">
          <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white mb-4">
            {website.title}
          </h1>
          {website.tagline && (
            <p class="text-xl text-slate-300 max-w-2xl mx-auto">
              {website.tagline}
            </p>
          )}
        </div>
      </section>
    ) : (
      <SectionsRenderer sections={page.sections} website={website} />
    )}
  </div>
</BaseLayout>

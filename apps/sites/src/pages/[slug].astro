---
/**
 * Dynamic Public Page - Renders any published website by slug
 * Uses the same renderers as the preview system for 100% visual parity
 * Route: /{slug}
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { 
  getPublicWebsite, 
  getPublicSections,
  type PublicSection,
} from '@/lib/api';
import { SectionRenderer } from '@asap/renderers';

// Get slug from URL
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Fetch website data
const website = await getPublicWebsite(slug);

// Handle 404
if (!website) {
  return Astro.redirect('/404');
}

// Only show published websites
if (website.status !== 'published') {
  return Astro.redirect('/404');
}

// Fetch sections
const rawSections = await getPublicSections(slug);

// Filter visible and sort by order
const sections = rawSections
  .filter(s => s.visible !== false)
  .sort((a, b) => (a.order_index || 0) - (b.order_index || 0));

// Extract theme and SEO from metadata
const theme = website.metadata?.theme;
const seoMeta = website.metadata?.seo || {};

// Build full SEO object
const seo = {
  title: seoMeta.title || website.title,
  description: seoMeta.description || website.tagline,
  keywords: seoMeta.keywords || [],
  author: seoMeta.author,
  image: seoMeta.image || website.metadata?.socialImage,
  url: `https://${slug}.asap.cool`,
  siteName: website.title,
  twitterHandle: seoMeta.twitterHandle,
  type: 'website' as const,
  canonicalUrl: seoMeta.canonicalUrl || `https://${slug}.asap.cool`,
  noIndex: seoMeta.noIndex || false,
  noFollow: seoMeta.noFollow || false,
};

// Convert sections to renderer format
const rendererSections = sections.map(s => ({
  id: s.id,
  website_id: s.website_id,
  section_type: s.section_type as any,
  title: s.title,
  layout: s.layout,
  content: s.content,
  data: s.content, // Alias for renderer compatibility
  settings: s.settings,
  visible: s.visible,
  order_index: s.order_index,
}));

// Convert website for renderer
const rendererWebsite = {
  id: website.id,
  slug: website.slug,
  title: website.title,
  tagline: website.tagline,
  status: website.status as 'draft' | 'published',
  metadata: website.metadata,
};
---

<BaseLayout 
  seo={seo} 
  theme={theme}
  favicon={website.metadata?.favicon}
  fontFamily={theme?.fontFamily}
>
  {rendererSections.length === 0 ? (
    <!-- Default hero when no sections configured -->
    <SectionRenderer 
      client:load
      section={{
        id: 'default-hero',
        website_id: website.id,
        section_type: 'hero',
        title: website.title,
        layout: 'centered',
        content: {
          headline: website.title,
          subheadline: website.tagline,
        },
        data: {
          headline: website.title,
          subheadline: website.tagline,
        },
        settings: {},
        visible: true,
        order_index: 0,
      }}
      website={rendererWebsite}
    />
  ) : (
    <!-- Render all sections using shared renderers -->
    {rendererSections.map((section) => (
      <SectionRenderer 
        client:load
        section={section} 
        website={rendererWebsite}
      />
    ))}
  )}
</BaseLayout>

---
/**
 * Dynamic Public Page - Renders any published website by slug
 * 100% SSR for optimal SEO - sections are rendered server-side via
 * `renderSection`, so the HTML response contains the actual content.
 * Route: /{slug}
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageNavigation from '@/components/site/PageNavigation.astro';
import { renderSection } from '@/lib/section-ssr';
import { buildSeo, getSiteData, getSiteRenderPayload, resolveSitePage } from '@/lib/site-data';
import { resolveTokens } from '@asap/shared';
import type { SiteData } from '@asap/site-runtime';

// Get slug from URL and normalize to lowercase for case-insensitive matching
const { slug: rawSlug } = Astro.params;
const slug = String(rawSlug || '').toLowerCase();

if (!slug) {
  return Astro.redirect('/');
}

const payload = await getSiteRenderPayload(slug);

if (!payload) {
  return Astro.redirect('/404');
}

const { website, theme, tokens } = payload;

if (website.status !== 'published') {
  return Astro.redirect('/404');
}

const page = resolveSitePage(payload);

if (!page) {
  return Astro.redirect('/404');
}

const seo = buildSeo(payload, page, slug);
const showNavigation = payload.pages.length > 1;

// Runtime payload for AI-generated sections. Collections + variables come
// from the public site-data endpoint; sections without compiled JS render
// an inline placeholder so unbuilt sections don't break the page.
const runtimeTokens = resolveTokens({ tokens, theme });
const siteDataPayload = await getSiteData(slug);
const runtimeData: SiteData = {
  collections: siteDataPayload.collections,
  variables: siteDataPayload.variables,
};

// Render every section to HTML in parallel. Sections with no compiled JS
// (or that fail to render) come back as `null` and fall back to the inline
// placeholder.
const renderedSections = await Promise.all(
  page.sections.map(async (section) => ({
    section,
    html: await renderSection({ section, tokens: runtimeTokens, data: runtimeData }),
  })),
);
---

<BaseLayout
  seo={seo}
  theme={theme}
  tokens={tokens}
  favicon={website.metadata?.favicon}
  fontFamily={tokens?.typography.bodyFamily ?? theme?.fontFamily}
>
  {showNavigation && (
    <PageNavigation
      pages={payload.pages}
      activeSlug={page.slug}
      siteSlug={slug}
      siteTitle={website.title}
    />
  )}

  <div class:list={[showNavigation && 'pt-20']}>
    {page.sections.length === 0 ? (
      <!-- Default hero when no elements configured -->
      <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
        <div class="text-center px-6">
          <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white mb-4">
            {website.title}
          </h1>
          {website.tagline && (
            <p class="text-xl text-slate-300 max-w-2xl mx-auto">
              {website.tagline}
            </p>
          )}
        </div>
      </section>
    ) : (
      renderedSections.map(({ section, html }) =>
        html ? (
          <div data-element-id={section.id} set:html={html} />
        ) : (
          <section
            data-element-id={section.id}
            class="py-12 px-6 border-y border-border bg-muted/30"
          >
            <div class="max-w-2xl mx-auto text-center">
              <p class="text-sm font-medium text-foreground/80">
                {section.title || section.element_type}
              </p>
              <p class="text-xs text-muted-foreground mt-1">
                Section not yet generated. Open the studio and ask the AI to
                generate this section.
              </p>
            </div>
          </section>
        )
      )
    )}
  </div>
</BaseLayout>

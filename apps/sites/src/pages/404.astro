---
/**
 * 404 Page - Site Not Found
 * 
 * Displayed when:
 * - The slug doesn't match any website
 * - The website is not published (draft status)
 */
import '@/styles/global.css';
---

<!DOCTYPE html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Site non trouvé | ASAP</title>
    <meta name="robots" content="noindex, nofollow" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center bg-slate-900 text-white">
    <div class="text-center px-6 max-w-lg">
      <!-- Animated 404 -->
      <div class="relative mb-8">
        <div class="absolute inset-0 bg-indigo-500/20 rounded-full blur-3xl"></div>
        <h1 class="relative text-9xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 via-violet-400 to-indigo-400">
          404
        </h1>
      </div>
      
      <!-- Message -->
      <h2 class="text-2xl font-semibold text-white mb-4">
        Site non trouvé
      </h2>
      <p class="text-slate-400 mb-8 leading-relaxed">
        Ce site n'existe pas ou n'a pas encore été publié.
        <br />
        Vérifiez l'URL ou contactez le propriétaire.
      </p>
      
      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="https://asap.cool" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-500 transition-all duration-200 shadow-lg shadow-indigo-600/25"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Accueil ASAP
        </a>
        <a 
          href="https://app.asap.cool" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-transparent text-white rounded-xl font-medium border-2 border-slate-600 hover:border-indigo-500 transition-all duration-200"
        >
          Créer mon site
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
    
    <!-- ASAP Branding -->
    <footer class="absolute bottom-8">
      <a 
        href="https://asap.cool" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-sm text-slate-500 hover:text-slate-400 transition-colors"
      >
        Propulsé par ASAP
      </a>
    </footer>
    
    <!-- Animated background -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-500/5 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-violet-500/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    </div>
  </body>
</html>

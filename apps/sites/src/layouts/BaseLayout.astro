---
/**
 * Base Layout - Shared HTML structure for all public sites
 */
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import type { SEOProps } from '@/components/SEO.astro';
import { buildThemeStyles, type Theme } from '@/lib/api';

interface Props {
  seo: SEOProps;
  theme?: Theme;
  favicon?: string;
  fontFamily?: string;
}

const { seo, theme, favicon, fontFamily } = Astro.props;

const themeClass = theme?.mode === 'light' ? 'light' : 'dark';
const themeStyles = buildThemeStyles(theme);
const fontUrl = fontFamily 
  ? `https://fonts.googleapis.com/css2?family=${encodeURIComponent(fontFamily)}:wght@400;500;600;700;800&display=swap`
  : 'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap';
---

<!DOCTYPE html>
<html lang="fr" class={themeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO -->
    <SEO {...seo} />
    
    <!-- Favicon -->
    {favicon ? (
      <link rel="icon" type="image/png" href={favicon} />
    ) : (
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    )}
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontUrl} rel="stylesheet" />
    
    <!-- Theme CSS Variables -->
    {themeStyles && (
      <style set:html={`:root { ${themeStyles} }`} />
    )}
    
    <!-- Performance hints -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    
    <!-- Canonical and alternates -->
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />
  </head>
  <body class="min-h-screen flex flex-col">
    <main class="flex-1">
      <slot />
    </main>
    
    <!-- Footer - Powered by ASAP -->
    <footer class="fixed bottom-4 right-4 z-50 no-print">
      <a 
        href="https://asap.cool" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-xs text-muted/50 hover:text-muted transition-colors"
      >
        Créé avec ASAP
      </a>
    </footer>
    
    <!-- Smooth scroll polyfill for older browsers -->
    <script>
      // Add intersection observer for section animations
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-up');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        
        document.querySelectorAll('section').forEach(section => {
          observer.observe(section);
        });
      }
    </script>
  </body>
</html>

---
/**
 * Base Layout - Shared HTML structure for all public sites
 * Optimized for Core Web Vitals (LCP, FID, CLS) and SEO
 */
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import type { SEOProps } from '@/components/SEO.astro';
import { buildThemeStyles, type Theme } from '@asap/shared';

interface Props {
  seo: SEOProps;
  theme?: Theme;
  favicon?: string;
  fontFamily?: string;
  socialImage?: string;
}

const { seo, theme, favicon, fontFamily, socialImage } = Astro.props;

const themeClass = theme?.mode === 'light' ? 'light' : 'dark';
const themeStyles = buildThemeStyles(theme);

// Font optimization: Use font-display: swap and preload critical fonts
const fontName = fontFamily || 'Inter';
const fontUrl = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(fontName)}:wght@400;500;600;700;800&display=swap`;

// Critical CSS inlined for faster FCP
const criticalCss = `
  :root { ${themeStyles || ''} }
  html { scroll-behavior: smooth; }
  body { 
    font-family: '${fontName}', system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
  /* Prevent CLS from font loading */
  .font-loading body { visibility: hidden; }
  .fonts-loaded body { visibility: visible; }
  /* Reduce CLS from images */
  img, video { max-width: 100%; height: auto; aspect-ratio: attr(width) / attr(height); }
`;
---

<!DOCTYPE html>
<html lang="fr" class={`${themeClass} font-loading`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Component (meta tags, OG, Twitter, JSON-LD) -->
    <SEO {...seo} />
    
    <!-- Favicon with multiple sizes for better compatibility -->
    {favicon ? (
      <>
        <link rel="icon" type="image/png" sizes="32x32" href={favicon} />
        <link rel="icon" type="image/png" sizes="16x16" href={favicon} />
        <link rel="apple-touch-icon" href={favicon} />
      </>
    ) : (
      <>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="apple-touch-icon" href="/favicon.svg" />
      </>
    )}
    
    <!-- Preconnect to critical origins (high priority) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- DNS prefetch for third-party resources -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    <link rel="dns-prefetch" href="//www.googletagmanager.com" />
    
    <!-- Preload critical font (improves LCP) -->
    <link 
      rel="preload" 
      href={`https://fonts.gstatic.com/s/${fontName.toLowerCase().replace(' ', '')}/v13/KFOmCnqEu92Fr1Mu4mxK.woff2`}
      as="font" 
      type="font/woff2" 
      crossorigin
    />
    
    <!-- Preload social image for OG/Twitter (if provided) -->
    {(socialImage || seo.image) && (
      <link rel="preload" href={socialImage || seo.image} as="image" />
    )}
    
    <!-- Critical CSS inline (improves FCP) -->
    <style set:html={criticalCss} />
    
    <!-- Load fonts with display=swap for better FCP -->
    <link href={fontUrl} rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href={fontUrl} rel="stylesheet" />
    </noscript>
    
    <!-- Resource hints for better performance -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />
    
    <!-- Manifest for PWA support -->
    <link rel="manifest" href="/manifest.json" />
    
    <!-- Speculation Rules API for instant navigation (Chrome 109+) -->
    <script type="speculationrules">
      {
        "prerender": [
          {
            "source": "document",
            "where": {
              "selector_matches": "a[href^='/']:not([rel=external])"
            },
            "eagerness": "moderate"
          }
        ],
        "prefetch": [
          {
            "source": "document",
            "where": {
              "selector_matches": "a[href^='/']:not([rel=external])"
            },
            "eagerness": "moderate"
          }
        ]
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <main class="flex-1">
      <slot />
    </main>
    
    <!-- Footer - Powered by ASAP -->
    <footer class="fixed bottom-4 right-4 z-50 no-print">
      <a 
        href="https://asap.cool" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-xs text-muted/50 hover:text-muted transition-colors"
      >
        Créé avec ASAP
      </a>
    </footer>
    
    <!-- Font loading detection (prevents CLS) -->
    <script>
      // Mark fonts as loaded when ready
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(() => {
          document.documentElement.classList.remove('font-loading');
          document.documentElement.classList.add('fonts-loaded');
        });
      } else {
        // Fallback for browsers without Font Loading API
        document.documentElement.classList.remove('font-loading');
        document.documentElement.classList.add('fonts-loaded');
      }
    </script>
    
    <!-- Intersection Observer for lazy animations (improves FID) -->
    <script>
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-up');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '50px' }
        );
        
        // Use requestIdleCallback for non-critical work
        const observeSections = () => {
          document.querySelectorAll('section[data-animate]').forEach(section => {
            observer.observe(section);
          });
        };
        
        if ('requestIdleCallback' in window) {
          requestIdleCallback(observeSections);
        } else {
          setTimeout(observeSections, 1);
        }
      }
    </script>
    
    <!-- Intelligent link prefetch for browsers without Speculation Rules -->
    <script>
      // Only run if Speculation Rules not supported
      if (!HTMLScriptElement.supports?.('speculationrules')) {
        const prefetchCache = new Set();
        
        const prefetchLink = (url) => {
          if (prefetchCache.has(url)) return;
          if (url.startsWith('/') && !url.includes('#')) {
            prefetchCache.add(url);
            const link = document.createElement('link');
            link.rel = 'prefetch';
            link.href = url;
            link.as = 'document';
            document.head.appendChild(link);
          }
        };
        
        // Prefetch on hover with debounce
        let hoverTimer;
        document.addEventListener('mouseover', (e) => {
          const anchor = e.target.closest('a[href^="/"]');
          if (anchor && !anchor.rel?.includes('external')) {
            hoverTimer = setTimeout(() => prefetchLink(anchor.href), 65);
          }
        });
        
        document.addEventListener('mouseout', (e) => {
          if (e.target.closest('a')) clearTimeout(hoverTimer);
        });
        
        // Prefetch visible links in navigation
        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            document.querySelectorAll('nav a[href^="/"]').forEach(link => {
              prefetchLink(link.href);
            });
          });
        }
      }
    </script>
  </body>
</html>

---
/**
 * Generic Section - SSR Astro Component
 * Fallback renderer for unknown element types
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

const title = element.title || 'Section';
const content = getData(element, 'content', '') || getData(element, 'description', '');
---

<section 
  id={element.slug || element.element_type}
  class="py-20 md:py-28 px-6 bg-white dark:bg-slate-900"
>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-12 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    {content && (
      <div class="prose prose-slate dark:prose-invert max-w-none">
        <p>{content}</p>
      </div>
    )}
    
    {!content && (
      <p class="text-center text-slate-500 dark:text-slate-400">
        Contenu à configurer.
      </p>
    )}
  </div>
</section>

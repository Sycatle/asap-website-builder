---
/**
 * About Section - SSR Astro Component
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

const title = element.title || 'À propos';
const description = getData(element, 'description', '') || getData(element, 'bio', '');
const image = getData(element, 'image', '') || getData(element, 'avatar', '');
const highlights = getData<string[]>(element, 'highlights', []);
const location = getData(element, 'location', '');
const layout = element.layout || 'default';
---

<section 
  id="about"
  class="py-20 md:py-28 px-6 bg-slate-50 dark:bg-slate-900/50"
>
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-12 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    <div class:list={[
      'grid gap-12 items-center',
      layout === 'split' && 'md:grid-cols-2'
    ]}>
      {image && layout === 'split' && (
        <div class="relative group">
          <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500/20 to-violet-500/20 rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <img 
            src={image} 
            alt="Profile"
            class="relative w-full max-w-md mx-auto rounded-2xl shadow-2xl object-cover aspect-[4/5]"
            loading="lazy"
          />
        </div>
      )}
      
      <div class="space-y-6">
        {description && (
          <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed whitespace-pre-line">
            {description}
          </p>
        )}
        
        {location && (
          <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{location}</span>
          </div>
        )}
        
        {highlights.length > 0 && (
          <ul class="space-y-3">
            {highlights.map((item) => (
              <li class="flex items-center gap-3 text-slate-700 dark:text-slate-200">
                <svg class="w-5 h-5 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>
</section>

---
/**
 * Contact Section - SSR Astro Component
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

const title = element.title || 'Contact';
const subtitle = getData(element, 'subtitle', "N'hésitez pas à me contacter pour discuter de votre projet.");
const email = getData(element, 'email', '');
const phone = getData(element, 'phone', '');
const location = getData(element, 'location', '');
const calendlyUrl = getData(element, 'calendly', '');
const socialLinks = getData<Record<string, string>>(element, 'socials', {});

const socials = Object.entries(socialLinks).filter(([_, url]) => url);
---

<section 
  id="contact"
  class="py-20 md:py-28 px-6 bg-slate-50 dark:bg-slate-900/50"
>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    {subtitle && (
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12 max-w-xl mx-auto">
        {subtitle}
      </p>
    )}
    
    <div class="grid gap-8 md:grid-cols-2">
      {/* Contact info */}
      <div class="space-y-4">
        {email && (
          <a 
            href={`mailto:${email}`}
            class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-slate-800 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors group border border-slate-200 dark:border-slate-700"
          >
            <div class="w-12 h-12 rounded-full bg-indigo-500/10 flex items-center justify-center group-hover:bg-indigo-500/20 transition-colors">
              <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-slate-400">Email</p>
              <p class="font-medium text-slate-900 dark:text-white">{email}</p>
            </div>
          </a>
        )}
        
        {phone && (
          <a 
            href={`tel:${phone}`}
            class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-slate-800 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors group border border-slate-200 dark:border-slate-700"
          >
            <div class="w-12 h-12 rounded-full bg-indigo-500/10 flex items-center justify-center group-hover:bg-indigo-500/20 transition-colors">
              <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-slate-400">Téléphone</p>
              <p class="font-medium text-slate-900 dark:text-white">{phone}</p>
            </div>
          </a>
        )}
        
        {location && (
          <div class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
            <div class="w-12 h-12 rounded-full bg-indigo-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-slate-400">Localisation</p>
              <p class="font-medium text-slate-900 dark:text-white">{location}</p>
            </div>
          </div>
        )}
        
        {/* Calendly button */}
        {calendlyUrl && (
          <a 
            href={calendlyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full p-4 rounded-xl bg-indigo-600 text-white hover:bg-indigo-500 transition-colors font-medium"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Réserver un appel
          </a>
        )}
        
        {/* Social links */}
        {socials.length > 0 && (
          <div class="flex flex-wrap gap-3 pt-4">
            {socials.map(([platform, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center hover:bg-indigo-500 hover:border-indigo-500 hover:text-white text-slate-600 dark:text-slate-300 transition-all duration-200"
                title={platform}
              >
                {platform === 'github' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                )}
                {platform === 'linkedin' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                )}
                {platform === 'twitter' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {!['github', 'linkedin', 'twitter'].includes(platform) && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                )}
              </a>
            ))}
          </div>
        )}
      </div>
      
      {/* Contact form */}
      <form class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 space-y-4">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">
          Envoyer un message
        </h3>
        
        <div>
          <label class="block text-sm text-slate-600 dark:text-slate-400 mb-1">Nom</label>
          <input 
            type="text" 
            name="name"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
            placeholder="Votre nom"
          />
        </div>
        
        <div>
          <label class="block text-sm text-slate-600 dark:text-slate-400 mb-1">Email</label>
          <input 
            type="email" 
            name="email"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
            placeholder="votre@email.com"
          />
        </div>
        
        <div>
          <label class="block text-sm text-slate-600 dark:text-slate-400 mb-1">Message</label>
          <textarea 
            name="message"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all resize-none"
            rows="4"
            placeholder="Votre message..."
          ></textarea>
        </div>
        
        <button 
          type="submit"
          class="w-full px-6 py-3 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-500 transition-colors"
        >
          Envoyer
        </button>
      </form>
    </div>
  </div>
</section>

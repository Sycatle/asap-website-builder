---
/**
 * Skills Section - SSR Astro Component
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

interface SkillCategory {
  name: string;
  skills: string[];
}

const title = element.title || 'Compétences';
const subtitle = getData(element, 'subtitle', '');
const categories = getData<SkillCategory[]>(element, 'categories', []);
const layout = element.layout || 'grid';
---

<section 
  id="skills"
  class="py-20 md:py-28 px-6 bg-white dark:bg-slate-900"
>
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    {subtitle && (
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    
    <div class:list={[
      'grid gap-6',
      layout === 'grid' ? 'md:grid-cols-2 lg:grid-cols-3' : 'md:grid-cols-2'
    ]}>
      {categories.map((category) => (
        <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 hover:border-indigo-500/50 transition-colors">
          <h3 class="text-xl font-semibold mb-4 text-indigo-600 dark:text-indigo-400">
            {category.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class="px-3 py-1.5 text-sm rounded-full bg-indigo-500/10 text-indigo-700 dark:text-indigo-300 font-medium">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    {categories.length === 0 && (
      <p class="text-center text-slate-500 dark:text-slate-400">
        Aucune compétence configurée.
      </p>
    )}
  </div>
</section>

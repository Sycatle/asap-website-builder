---
/**
 * Hero Section - SSR Astro Component
 * Renders the hero section server-side for optimal SEO
 */
import type { Element, Website } from '@asap/shared';

interface Props {
  element: Element;
  website?: Website;
}

const { element, website } = Astro.props;

// Helper to get data from element
function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

// Extract data from element
const name = getData(element, 'name', '') || getData(element, 'headline', '') || website?.title || 'Votre Nom';
const title = getData(element, 'title', 'Développeur Full Stack');
const subtitle = getData(element, 'subtitle', '') || getData(element, 'subheadline', '') || website?.tagline || '';
const tagline = getData(element, 'tagline', '');
const avatar = getData(element, 'avatar', '');
const ctaText = getData(element, 'cta_text', '') || getData(element, 'ctaText', 'Voir mes projets');
const ctaLink = getData(element, 'cta_link', '') || getData(element, 'ctaLink', '#projects');
const secondaryCta = getData(element, 'secondary_cta', '') || getData(element, 'secondaryCta', '');
const secondaryCtaLink = getData(element, 'secondary_cta_link', '') || getData(element, 'secondaryCtaLink', '#contact');
const availability = getData(element, 'availability', 'available');

const availabilityConfig: Record<string, { label: string; color: string }> = {
  available: { label: 'Disponible', color: 'bg-green-500' },
  busy: { label: 'Occupé', color: 'bg-yellow-500' },
  'not-available': { label: 'Indisponible', color: 'bg-red-500' },
};
const availStatus = availabilityConfig[availability] || availabilityConfig.available;
---

<section 
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"
>
  <!-- Gradient decorations -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(99,102,241,0.15),transparent_70%)]"></div>
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 py-20 max-w-4xl mx-auto">
    <!-- Avatar if provided -->
    {avatar && (
      <div class="mb-8">
        <img 
          src={avatar} 
          alt={name}
          class="w-32 h-32 mx-auto rounded-full border-4 border-white/20 shadow-2xl object-cover"
          loading="eager"
        />
      </div>
    )}
    
    <!-- Availability badge -->
    {availability && (
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm mb-6">
        <span class={`h-2 w-2 rounded-full ${availStatus.color}`}></span>
        <span class="text-sm text-white/80">{availStatus.label}</span>
      </div>
    )}
    
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white mb-4 tracking-tight">
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-indigo-200 to-white">
        {name}
      </span>
    </h1>
    
    <h2 class="text-xl sm:text-2xl md:text-3xl text-indigo-400 font-medium mb-6">
      {title}
    </h2>
    
    {(subtitle || tagline) && (
      <p class="text-lg md:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed">
        {subtitle || tagline}
      </p>
    )}
    
    <div class="flex flex-wrap items-center justify-center gap-4">
      {ctaText && (
        <a 
          href={ctaLink}
          class="inline-flex items-center gap-2 px-8 py-4 bg-indigo-600 text-white rounded-xl font-semibold text-lg hover:bg-indigo-500 transition-all duration-200 shadow-lg shadow-indigo-600/25 hover:shadow-xl hover:shadow-indigo-600/30 hover:-translate-y-0.5"
        >
          {ctaText}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}
      
      {secondaryCta && (
        <a 
          href={secondaryCtaLink}
          class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-white rounded-xl font-semibold text-lg border-2 border-slate-600 hover:border-indigo-500 transition-all duration-200"
        >
          {secondaryCta}
        </a>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>

  <!-- Bottom gradient line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-500/50 to-transparent"></div>
</section>

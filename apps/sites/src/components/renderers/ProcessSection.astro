---
/**
 * Process Section - SSR Astro Component
 * Shows how the freelancer works (steps)
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

interface Step {
  title: string;
  description: string;
  icon?: string;
}

const title = element.title || 'Mon Processus';
const subtitle = getData(element, 'subtitle', 'Comment je travaille');
const steps = getData<Step[]>(element, 'steps', []);
---

<section 
  id="process"
  class="py-20 md:py-28 px-6 bg-slate-50 dark:bg-slate-900/50"
>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    {subtitle && (
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    
    <div class="relative">
      {/* Vertical line */}
      <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gradient-to-b from-indigo-500 via-violet-500 to-indigo-500 hidden md:block"></div>
      
      <div class="space-y-8">
        {steps.map((step, index) => (
          <div class="relative flex gap-6 items-start">
            {/* Step number */}
            <div class="relative z-10 flex-shrink-0 w-16 h-16 rounded-2xl bg-indigo-600 text-white flex items-center justify-center font-bold text-xl shadow-lg shadow-indigo-600/25">
              {index + 1}
            </div>
            
            {/* Content */}
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-semibold mb-2 text-slate-900 dark:text-white">
                {step.title}
              </h3>
              <p class="text-slate-600 dark:text-slate-300">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    {steps.length === 0 && (
      <p class="text-center text-slate-500 dark:text-slate-400">
        Aucune étape configurée.
      </p>
    )}
  </div>
</section>

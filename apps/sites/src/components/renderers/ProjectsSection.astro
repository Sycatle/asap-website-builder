---
/**
 * Projects Section - SSR Astro Component
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

interface Project {
  title: string;
  description?: string;
  image?: string;
  tags?: string[];
  link?: string;
  github?: string;
  featured?: boolean;
}

const title = element.title || 'Projets';
const subtitle = getData(element, 'subtitle', '');
const projects = getData<Project[]>(element, 'projects', []);
const layout = element.layout || 'grid';
---

<section 
  id="projects"
  class="py-20 md:py-28 px-6 bg-slate-50 dark:bg-slate-900/50"
>
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    {subtitle && (
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    
    <div class:list={[
      'grid gap-6',
      layout === 'grid' ? 'md:grid-cols-2 lg:grid-cols-3' : ''
    ]}>
      {projects.map((project) => (
        <article class="group rounded-2xl overflow-hidden bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-xl hover:border-indigo-500/30 transition-all duration-300">
          {project.image && (
            <div class="aspect-video bg-slate-200 dark:bg-slate-700 overflow-hidden">
              <img 
                src={project.image} 
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          )}
          
          <div class="p-6">
            {project.featured && (
              <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded-full bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 mb-3">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                Projet phare
              </span>
            )}
            
            <h3 class="text-xl font-semibold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              {project.title}
            </h3>
            
            {project.description && (
              <p class="text-slate-600 dark:text-slate-300 mb-4 line-clamp-2">
                {project.description}
              </p>
            )}
            
            {project.tags && project.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {project.tags.slice(0, 5).map((tag) => (
                  <span class="px-2 py-1 text-xs rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
                    {tag}
                  </span>
                ))}
              </div>
            )}
            
            <div class="flex gap-3">
              {project.link && (
                <a 
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-500 transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Voir
                </a>
              )}
              {project.github && (
                <a 
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  Code
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
    
    {projects.length === 0 && (
      <p class="text-center text-slate-500 dark:text-slate-400">
        Aucun projet configuré.
      </p>
    )}
  </div>
</section>

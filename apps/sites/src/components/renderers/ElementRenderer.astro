---
/**
 * Element Renderer - SSR Astro Component
 * Routes to the correct section renderer based on element_type
 * 100% Server-Side Rendered for optimal SEO
 */
import type { Element, Website } from '@asap/shared';

// Import all section renderers
import HeroSection from './HeroSection.astro';
import AboutSection from './AboutSection.astro';
import ServicesSection from './ServicesSection.astro';
import ProjectsSection from './ProjectsSection.astro';
import SkillsSection from './SkillsSection.astro';
import ProcessSection from './ProcessSection.astro';
import ProofSection from './ProofSection.astro';
import ContactSection from './ContactSection.astro';
import GenericSection from './GenericSection.astro';
import NavigationSection from './saas/NavigationSection.astro';
import FeaturesSection from './saas/FeaturesSection.astro';
import HowItWorksSection from './saas/HowItWorksSection.astro';
import PricingSection from './saas/PricingSection.astro';
import TestimonialsSection from './saas/TestimonialsSection.astro';
import CTASection from './saas/CTASection.astro';
import FooterSection from './saas/FooterSection.astro';

interface Props {
  element: Element;
  website?: Website;
}

const { element, website } = Astro.props;

// Normalize element payloads coming from the API. Some backends
// use `settings` or `content` while renderers expect `data`.
const normalizedElement: Element = {
  ...element,
  data: (element.data ?? (element as any).settings ?? element.content ?? {}) as any,
};

// Map element types to components
const rendererMap: Record<string, any> = {
  hero: HeroSection,
  about: AboutSection,
  services: ServicesSection,
  projects: ProjectsSection,
  skills: SkillsSection,
  process: ProcessSection,
  proof: ProofSection,
  contact: ContactSection,
  navigation: NavigationSection,
  features: FeaturesSection,
  'how-it-works': HowItWorksSection,
  pricing: PricingSection,
  testimonials: TestimonialsSection,
  cta: CTASection,
  footer: FooterSection,
};

// Get the appropriate renderer
const Renderer = rendererMap[element.element_type] || GenericSection;
---

<Renderer element={normalizedElement} website={website} />

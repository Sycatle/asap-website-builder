---
/**
 * Navigation Section - SaaS Landing
 * Renders the navigation bar for SaaS landing pages
 */
const { element } = Astro.props;
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <nav class="container mx-auto flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary">
        <svg class="h-5 w-5 text-primary-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l4 2" />
        </svg>
      </div>
      <span class="text-xl font-bold">{element.data?.brandName || 'ASAP'}</span>
    </div>

    <div class="hidden md:flex items-center gap-8">
      {(() => {
        const links = (element.data?.links || []) as any[];
        return links.map((link: any) => (
          <a href={link.href} class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">{link.label}</a>
        ));
      })()}
    </div>

    <div class="hidden md:flex items-center gap-4">
      {element.data?.loginHref && (
        <a href={element.data.loginHref} class="text-sm font-medium text-muted-foreground hover:text-foreground">{element.data.loginLabel || 'Log in'}</a>
      )}
      {element.data?.signupHref && (
        <a href={element.data.signupHref} class="inline-flex items-center rounded-md bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground">{element.data.signupLabel || 'Get started'}</a>
      )}
    </div>
  </nav>
</header>
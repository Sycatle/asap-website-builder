---
/**
 * Features Section - SaaS Landing
 */
const { element } = Astro.props;
const items = (element.data?.items || []) as any[];
---

<section id="features" class="py-20 md:py-32 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center mb-16">
      {element.data?.badge && <div class="mb-4 px-4 py-2 inline-block rounded-full border">{element.data.badge}</div>}
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl mb-4">
        {element.data?.titleLine1 || element.data?.headline}
        {element.data?.titleLine2 && <span class="text-primary"> {element.data.titleLine2}</span>}
      </h2>
      {element.data?.subtitle && <p class="text-lg text-muted-foreground">{element.data.subtitle}</p>}
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="relative group hover:shadow-lg transition-all duration-300 hover:-translate-y-1 p-6 rounded-lg border bg-card">
          {item.badge && <div class="absolute -top-2 -right-2 inline-block rounded px-2 py-1 text-xs bg-muted">{item.badge}</div>}
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 group-hover:bg-primary/20 transition-colors">
            {item.icon ? <img src={item.icon} class="h-6 w-6" alt="" /> : <div class="h-6 w-6" />}
          </div>
          <div class="text-xl font-semibold mb-2">{item.title}</div>
          <div class="text-base text-muted-foreground">{item.description}</div>
        </div>
      ))}
    </div>
  </div>
</section>
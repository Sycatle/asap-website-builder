---
/**
 * Pricing Section - SaaS Landing
 */
const { element } = Astro.props;
const plans = (element.data?.plans || []) as any[];
---

<section id="pricing" class="py-20 md:py-32 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center mb-16">
      {element.data?.badge && <div class="mb-4 inline-block rounded-full border px-3 py-1 text-sm">{element.data.badge}</div>}
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl mb-4">
        {element.data?.titleLine1 || element.data?.headline}
        {element.data?.titleLine2 && <span class="text-primary"> {element.data.titleLine2}</span>}
      </h2>
      {element.data?.subtitle && <p class="text-lg text-muted-foreground">{element.data.subtitle}</p>}
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {plans.map((plan) => (
        <div class="p-6 rounded-lg border bg-card flex flex-col">
          <div class="mb-4">
            <h3 class="text-xl font-bold">{plan.name}</h3>
            <div class="text-3xl font-extrabold mt-2">{plan.price}</div>
            <div class="text-muted-foreground">{plan.period || plan.interval || 'per month'}</div>
          </div>
          <ul class="mb-6 flex-1 text-muted-foreground">
            {(plan.features || []).map((f: any) => (
              <li class="mb-2">{f}</li>
            ))}
          </ul>
          {plan.cta && (
            <a href={plan.cta.href || '#'} class="inline-flex items-center rounded-md bg-primary px-8 py-3 text-base font-semibold text-primary-foreground mt-auto">{plan.cta.label || plan.cta}</a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
---
/**
 * How It Works Section - SaaS Landing
 */
const { element } = Astro.props;
const steps = (element.data?.steps || []) as any[];
---

<section id="demo" class="py-20 md:py-32">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center mb-16">
      {element.data?.badge && <div class="mb-4 inline-block rounded-full border px-3 py-1 text-sm">{element.data.badge}</div>}
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl mb-4">
        {element.data?.titleLine1 || element.data?.headline} <span class="text-primary">{element.data?.titleLine2}</span>
      </h2>
      {element.data?.subtitle && <p class="text-lg text-muted-foreground">{element.data.subtitle}</p>}
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((s, i) => (
        <div class="relative">
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-[60%] w-full h-0.5 bg-gradient-to-r from-primary/50 to-primary/10" />
          )}
          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary text-primary-foreground text-2xl font-bold">
              {s.number || (i+1).toString().padStart(2,'0')}
            </div>
            <h3 class="text-lg font-semibold mb-2">{s.title}</h3>
            <p class="text-muted-foreground">{s.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
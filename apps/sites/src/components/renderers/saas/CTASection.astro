---
/**
 * CTA Section - SaaS Landing
 */
const { element } = Astro.props;
---

<section class="py-20 bg-primary/5">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold">{element.data?.headline || 'Get started today'}</h2>
      {element.data?.subheadline && <p class="mx-auto max-w-2xl text-muted-foreground mt-3">{element.data.subheadline}</p>}
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
        {element.data?.ctaPrimary && (
          <a href={element.data.ctaPrimary.href || '/signup'} class="inline-flex items-center rounded-md bg-primary px-8 py-3 text-base font-semibold text-primary-foreground">
            {element.data.ctaPrimary.label}
            <svg class="ml-2 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        )}
        {element.data?.ctaSecondary && (
          <a href={element.data.ctaSecondary.href || '#'} class="inline-flex items-center rounded-md border border-muted/20 px-8 py-3 text-base font-semibold">{element.data.ctaSecondary.label}</a>
        )}
      </div>
    </div>
  </div>
</section>
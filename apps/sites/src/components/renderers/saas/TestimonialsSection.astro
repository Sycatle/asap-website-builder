---
/**
 * Testimonials Section - SaaS Landing
 */
const { element } = Astro.props;
const items = (element.data?.testimonials || []) as any[];
---

<section id="testimonials" class="py-20 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center mb-16">
      {element.data?.badge && <div class="mb-4 inline-block rounded-full border px-3 py-1 text-sm">{element.data.badge}</div>}
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl mb-4">{element.data?.title || element.data?.headline}</h2>
      {element.data?.subtitle && <p class="text-lg text-muted-foreground">{element.data.subtitle}</p>}
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {items.map(item => (
        <blockquote class="p-6 rounded-lg border bg-card">
          <p class="italic text-muted-foreground">"{item.content}"</p>
          <div class="mt-4 flex items-center gap-3">
            {item.avatar && <img src={item.avatar} alt="" class="h-10 w-10 rounded-full" />}
            <div>
              <div class="font-semibold">{item.name}</div>
              <div class="text-sm text-muted-foreground">{item.role}</div>
            </div>
          </div>
        </blockquote>
      ))}
    </div>
  </div>
</section>
---
/**
 * Footer Section - SaaS Landing
 */
const { element } = Astro.props;
---

<footer class="border-t bg-background py-8">
  <div class="container mx-auto px-4">
      <div class="flex flex-col gap-6 md:flex-row md:justify-between md:items-center">
        <div>
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 rounded bg-primary/20"></div>
            <div class="font-semibold">{element.data?.brandName || 'Brand'}</div>
          </div>
          {element.data?.copyright && <div class="text-sm text-muted-foreground mt-2">{element.data.copyright}</div>}
        </div>

        <div class="flex items-center gap-4">
          {(() => {
            const links = (element.data?.links || []) as any[];
            return links.map((link: any) => (
              <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground">{link.label}</a>
            ));
          })()}
        </div>
      </div>
  </div>
</footer>
---
/**
 * Proof Section - SSR Astro Component
 * Testimonials and social proof
 */
import type { Element } from '@asap/shared';

interface Props {
  element: Element;
}

const { element } = Astro.props;

function getData<T>(el: Element, key: string, defaultValue: T): T {
  const data = el.data ?? el.content ?? {};
  return (data[key] as T) ?? defaultValue;
}

interface Testimonial {
  content: string;
  author: string;
  role?: string;
  company?: string;
  avatar?: string;
  rating?: number;
}

const title = element.title || 'Témoignages';
const subtitle = getData(element, 'subtitle', '');
const testimonials = getData<Testimonial[]>(element, 'testimonials', []);
---

<section 
  id="proof"
  class="py-20 md:py-28 px-6 bg-white dark:bg-slate-900"
>
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-slate-900 dark:text-white">
      {title}
    </h2>
    
    {subtitle && (
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
          {/* Quote icon */}
          <svg class="w-8 h-8 text-indigo-500/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z"/>
          </svg>
          
          {/* Rating stars */}
          {testimonial.rating && (
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map((_, i) => (
                <svg 
                  class:list={[
                    'w-4 h-4',
                    i < (testimonial.rating ?? 0) ? 'text-yellow-400' : 'text-slate-300 dark:text-slate-600'
                  ]}
                  fill="currentColor" 
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          )}
          
          <p class="text-slate-600 dark:text-slate-300 mb-6 italic">
            "{testimonial.content}"
          </p>
          
          <div class="flex items-center gap-3">
            {testimonial.avatar ? (
              <img 
                src={testimonial.avatar} 
                alt={testimonial.author}
                class="w-12 h-12 rounded-full object-cover"
                loading="lazy"
              />
            ) : (
              <div class="w-12 h-12 rounded-full bg-indigo-500/10 flex items-center justify-center text-indigo-600 font-semibold">
                {testimonial.author.charAt(0).toUpperCase()}
              </div>
            )}
            <div>
              <p class="font-semibold text-slate-900 dark:text-white">
                {testimonial.author}
              </p>
              <p class="text-sm text-slate-500">
                {testimonial.role}{testimonial.company && ` @ ${testimonial.company}`}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    {testimonials.length === 0 && (
      <p class="text-center text-slate-500 dark:text-slate-400">
        Aucun témoignage configuré.
      </p>
    )}
  </div>
</section>

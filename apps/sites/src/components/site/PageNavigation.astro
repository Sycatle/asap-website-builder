---
import type { SiteRenderPage } from '@asap/shared';

interface Props {
  pages: SiteRenderPage[];
  activeSlug: string;
  siteSlug: string;
  siteTitle: string;
}

const { pages, activeSlug, siteSlug, siteTitle } = Astro.props;
const navPages = pages
  .filter((page) => page.visible !== false)
  .map((page) => ({
    title: page.title,
    slug: page.slug,
    href: page.is_homepage ? `/${siteSlug}` : `/${siteSlug}/${page.slug}`,
    active: page.slug === activeSlug,
  }));
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`/${siteSlug}`} class="font-bold text-lg text-foreground">
      {siteTitle}
    </a>
    <div class="flex items-center gap-4">
      {navPages.map((navPage) => (
        <a
          href={navPage.href}
          class:list={[
            'text-sm font-medium transition-colors',
            navPage.active ? 'text-primary' : 'text-muted hover:text-foreground',
          ]}
        >
          {navPage.title}
        </a>
      ))}
    </div>
  </div>
</nav>

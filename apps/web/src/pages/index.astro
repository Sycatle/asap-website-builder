---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="ASAP - Site web en 5 minutes">
  <div class="min-h-screen">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <h1 class="text-2xl font-bold text-primary-600">ASAP</h1>
          </div>
          <div class="flex items-center gap-4">
            <Button href="/login" variant="secondary" size="sm">
              Se connecter
            </Button>
            <Button href="/signup" size="sm">
              Commencer
            </Button>
          </div>
        </div>
      </nav>
    </header>

    <!-- Hero Section -->
    <section class="bg-gradient-to-b from-white to-gray-50 py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-5xl font-bold text-gray-900 mb-6">
            Créez votre site professionnel
            <span class="text-primary-600">en 5 minutes</span>
          </h2>
          <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
            Importez vos projets GitHub, personnalisez votre présentation, publiez. C'est fait.
          </p>
          <div class="flex justify-center gap-4">
            <Button href="/signup" size="lg">
              Commencer gratuitement
            </Button>
            <Button href="#features" variant="secondary" size="lg">
              En savoir plus
            </Button>
          </div>
        </div>

        <!-- Preview Screenshot Placeholder -->
        <div class="mt-16">
          <div class="bg-white rounded-xl shadow-2xl overflow-hidden border border-gray-200">
            <div class="bg-gray-100 px-4 py-3 flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <div class="p-8 bg-gradient-to-br from-primary-50 to-purple-50 h-96 flex items-center justify-center">
              <p class="text-gray-500 text-lg">Dashboard Preview</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">
            Tout ce dont vous avez besoin
          </h2>
          <p class="text-xl text-gray-600">
            Une plateforme complète pour gérer vos projets et votre présence en ligne
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Feature 1: GitHub Import -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
              Import GitHub automatique
            </h3>
            <p class="text-gray-600">
              Importez automatiquement vos projets GitHub avec descriptions, technologies et statistiques.
            </p>
          </div>

          <!-- Feature 2: Cloud Storage -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
              Stockage cloud intégré
            </h3>
            <p class="text-gray-600">
              Hébergez vos fichiers, images et documents avec 1 GB de stockage gratuit.
            </p>
          </div>

          <!-- Feature 3: Custom Domains -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
              Publication instantanée
            </h3>
            <p class="text-gray-600">
              Publiez votre site en un clic sur un sous-domaine ASAP ou votre propre domaine.
            </p>
          </div>

          <!-- Feature 4: Modules -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
              Système de modules
            </h3>
            <p class="text-gray-600">
              Activez les fonctionnalités dont vous avez besoin: analytics, IA, thèmes personnalisés.
            </p>
          </div>

          <!-- Feature 5: Multi-tenant -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
              Gestion multi-utilisateurs
            </h3>
            <p class="text-gray-600">
              Créez des comptes pour vos clients et gérez tous leurs sites depuis un seul endroit.
            </p>
          </div>

          <!-- Feature 6: Security -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
              Sécurité & Performance
            </h3>
            <p class="text-gray-600">
              Backend Rust ultra-rapide avec isolation des données et caching Redis intégré.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-primary-600 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Prêt à créer votre site ?
        </h2>
        <p class="text-xl text-primary-100 mb-8">
          Rejoignez des centaines de développeurs qui utilisent ASAP
        </p>
        <Button href="/signup" size="lg" class="bg-white text-primary-600 hover:bg-gray-100">
          Commencer gratuitement
        </Button>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-xl font-bold mb-4">ASAP</h3>
            <p class="text-gray-400">
              Plateforme SaaS pour créateurs et entrepreneurs.
            </p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Produit</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="#features" class="hover:text-white">Fonctionnalités</a></li>
              <li><a href="#" class="hover:text-white">Pricing</a></li>
              <li><a href="#" class="hover:text-white">Documentation</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Entreprise</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="#" class="hover:text-white">À propos</a></li>
              <li><a href="#" class="hover:text-white">Blog</a></li>
              <li><a href="#" class="hover:text-white">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Légal</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="#" class="hover:text-white">Confidentialité</a></li>
              <li><a href="#" class="hover:text-white">CGU</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
          <p>&copy; 2024 ASAP. Tous droits réservés.</p>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

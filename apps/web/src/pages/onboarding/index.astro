---
/**
 * V1 MVP: Onboarding Entry Point
 * 
 * Creates a new website and redirects to the onboarding wizard.
 * Route: /onboarding
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Démarrer | ASAP">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-4">
      <div class="animate-spin h-8 w-8 border-2 border-primary border-t-transparent rounded-full mx-auto"></div>
      <p class="text-muted-foreground">Préparation de votre espace...</p>
    </div>
  </div>
  
  <script>
    // Create a new website and redirect to onboarding
    (async function() {
      try {
        const token = localStorage.getItem('auth_token');
        
        if (!token) {
          // Not logged in, redirect to login with return URL
          window.location.href = '/login?redirect=/onboarding';
          return;
        }

        // Create new website
        const response = await fetch('/api/websites', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`,
          },
          body: JSON.stringify({
            preset_id: 'a0000001-0001-4001-8001-000000000001', // V1 Dev Freelance preset
            name: 'Mon Portfolio',
          }),
        });

        if (response.ok) {
          const data = await response.json();
          window.location.href = `/onboarding/${data.id}`;
        } else {
          console.error('Failed to create website');
          // Fallback to demo mode
          window.location.href = '/onboarding/demo';
        }
      } catch (error) {
        console.error('Error creating website:', error);
        // Fallback to demo mode
        window.location.href = '/onboarding/demo';
      }
    })();
  </script>
</BaseLayout>

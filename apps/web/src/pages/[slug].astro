---
/**
 * Dynamic public page for published websites
 * Route: /{slug}
 */
import PublicSite from '@/components/public/PublicSite';

// Get the slug from the URL
const { slug } = Astro.params;

// Fetch website data from the API
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';

let website = null;
let sections = [];
let error = null;

try {
  // Fetch website by slug
  const websiteResponse = await fetch(`${API_URL}/public/websites/${slug}`);
  
  if (websiteResponse.status === 404) {
    return Astro.redirect('/404');
  }
  
  if (!websiteResponse.ok) {
    throw new Error(`Failed to fetch website: ${websiteResponse.statusText}`);
  }
  
  website = await websiteResponse.json();
  
  // If website is not published, redirect to 404
  if (website.status !== 'published') {
    return Astro.redirect('/404');
  }
  
  // Try to fetch sections (may not exist on all backends)
  try {
    const sectionsResponse = await fetch(`${API_URL}/public/websites/${slug}/sections`);
    if (sectionsResponse.ok) {
      sections = await sectionsResponse.json();
    }
  } catch (e) {
    console.warn('Could not fetch sections:', e);
  }
} catch (e) {
  console.error('Error fetching website:', e);
  error = e instanceof Error ? e.message : 'Unknown error';
}

// Extract theme from metadata
const theme = website?.metadata?.theme || {
  primaryColor: '#6366f1',
  backgroundColor: '#0f172a',
  textColor: '#f8fafc',
  accentColor: '#8b5cf6',
};

const title = website?.title || 'Site non trouvé';
const description = website?.tagline || '';
---

<!DOCTYPE html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://${slug}.asap.cool`} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Theme CSS Variables -->
    <style define:vars={{
      'primary': theme.primaryColor,
      'bg': theme.backgroundColor,
      'text': theme.textColor,
      'accent': theme.accentColor,
    }}>
      :root {
        --primary-color: var(--primary);
        --background-color: var(--bg);
        --text-color: var(--text);
        --accent-color: var(--accent);
      }
      
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      
      html {
        scroll-behavior: smooth;
      }
      
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: var(--background-color);
        color: var(--text-color);
        line-height: 1.6;
        min-height: 100vh;
      }
      
      a {
        color: var(--primary-color);
        text-decoration: none;
      }
      
      a:hover {
        text-decoration: underline;
      }
      
      /* Smooth scroll indicator */
      @keyframes scroll-hint {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(8px); }
      }
      
      .scroll-indicator {
        animation: scroll-hint 2s ease-in-out infinite;
      }
      
      /* Section transitions */
      section {
        opacity: 0;
        transform: translateY(20px);
        animation: section-appear 0.6s ease-out forwards;
      }
      
      section:nth-child(1) { animation-delay: 0s; }
      section:nth-child(2) { animation-delay: 0.1s; }
      section:nth-child(3) { animation-delay: 0.2s; }
      section:nth-child(4) { animation-delay: 0.3s; }
      section:nth-child(5) { animation-delay: 0.4s; }
      
      @keyframes section-appear {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </head>
  <body>
    {error ? (
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; text-align: center;">
        <h1 style="font-size: 2rem; margin-bottom: 1rem;">Oops!</h1>
        <p style="color: #94a3b8; margin-bottom: 2rem;">Une erreur est survenue lors du chargement du site.</p>
        <a href="/" style="padding: 0.75rem 1.5rem; background: var(--primary-color); color: white; border-radius: 0.5rem;">
          Retour à l'accueil
        </a>
      </div>
    ) : website ? (
      <PublicSite 
        client:load 
        website={website} 
        sections={sections} 
        theme={theme}
      />
    ) : (
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; text-align: center;">
        <h1 style="font-size: 2rem; margin-bottom: 1rem;">Site non trouvé</h1>
        <p style="color: #94a3b8; margin-bottom: 2rem;">Ce site n'existe pas ou n'est pas encore publié.</p>
        <a href="/" style="padding: 0.75rem 1.5rem; background: var(--primary-color); color: white; border-radius: 0.5rem;">
          Retour à l'accueil
        </a>
      </div>
    )}
    
    <!-- Powered by ASAP -->
    <footer style="position: fixed; bottom: 1rem; right: 1rem; opacity: 0.5; font-size: 0.75rem;">
      <a href="https://asap.cool" target="_blank" rel="noopener" style="color: inherit;">
        Créé avec ASAP
      </a>
    </footer>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResetPasswordForm from '../components/ResetPasswordForm';
import { Card, CardContent } from '@/components/ui/card';
---

<BaseLayout title="Réinitialiser le mot de passe - ASAP">
  <div class="flex min-h-svh flex-col items-center justify-center gap-6 bg-muted p-6 md:p-10">
    <div class="flex w-full max-w-sm flex-col gap-6">
      <Card className="overflow-hidden">
        <CardContent className="p-6 md:p-8">
          <ResetPasswordForm client:load />
        </CardContent>
      </Card>
      <div class="text-balance text-center text-xs text-muted-foreground">
        Besoin d'aide ?{' '}
        <a href="mailto:support@asap.cool" class="underline underline-offset-4 hover:text-primary">Contactez-nous</a>
      </div>
    </div>
  </div>
</BaseLayout>

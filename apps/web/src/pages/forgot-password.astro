---
import BaseLayout from '../layouts/BaseLayout.astro';
import ForgotPasswordForm from '../components/ForgotPasswordForm';
import { Card, CardContent } from '@/components/ui/card';
---

<BaseLayout title="Mot de passe oublié - ASAP">
  <div class="flex min-h-svh flex-col items-center justify-center gap-6 bg-muted p-6 md:p-10">
    <div class="flex w-full max-w-sm flex-col gap-6">
      <Card className="overflow-hidden">
        <CardContent className="p-6 md:p-8">
          <ForgotPasswordForm client:load />
        </CardContent>
      </Card>
      <div class="text-balance text-center text-xs text-muted-foreground">
        Vous vous souvenez de votre mot de passe ?{' '}
        <a href="/login" class="underline underline-offset-4 hover:text-primary">Se connecter</a>
      </div>
    </div>
  </div>
</BaseLayout>

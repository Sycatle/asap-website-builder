# Development Dockerfile for Worker with hot reload
# Uses shared base image to avoid duplicating dependency installation
FROM asap-base-rust:dev

# Copy all source code (will be overwritten by volume mounts in docker-compose)
COPY core ./core
COPY apps ./apps
COPY extensions ./extensions
COPY .sqlx ./.sqlx

# Use cargo-watch for hot reload
CMD ["cargo", "watch", "-x", "run --bin asap-worker", "-w", "apps/worker", "-w", "core", "-w", "extensions"]

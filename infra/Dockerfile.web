# ============================================================================
# Dockerfile for ASAP Web (Dashboard SPA)
# Development: Vite dev server via shared base image
# Production: Multi-stage build → static assets served by nginx
# ============================================================================

# For development - use base image
FROM asap-base-node:dev AS dev

# Copy source code (node_modules excluded via .dockerignore)
COPY packages/shared ./packages/shared
COPY packages/renderers ./packages/renderers
COPY apps/web ./apps/web

WORKDIR /app/apps/web

ENV HOST=0.0.0.0
ENV PORT=4321

EXPOSE 4321

CMD ["./node_modules/.bin/vite", "--host", "0.0.0.0", "--port", "4321"]

# ============================================================================
# For production - separate build (not using base image)
# ============================================================================
FROM node:20-alpine AS base

RUN corepack enable && corepack prepare pnpm@latest --activate

# ============================================================================
# Dependencies stage
# ============================================================================
FROM base AS deps

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/renderers/package.json ./packages/renderers/
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile

# ============================================================================
# Builder stage
# ============================================================================
FROM base AS builder

WORKDIR /app

COPY --from=deps /app ./
COPY packages/shared ./packages/shared
COPY packages/renderers ./packages/renderers
COPY apps/web ./apps/web

WORKDIR /app/apps/web
RUN pnpm vite build

# ============================================================================
# Runtime stage - nginx static
# ============================================================================
FROM nginx:1.31-alpine AS runtime

# Drop default config
RUN rm /etc/nginx/conf.d/default.conf

COPY infra/nginx/web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

EXPOSE 4321

# nginx runs in foreground by default with this image
CMD ["nginx", "-g", "daemon off;"]

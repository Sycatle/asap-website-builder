# ============================================================================
# Dockerfile for ASAP Web (Dashboard Application)
# Multi-stage build for optimized production image
# ============================================================================

FROM node:20-alpine AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# ============================================================================
# Dependencies stage - Install all workspace dependencies
# ============================================================================
FROM base AS deps

WORKDIR /app

# Copy workspace root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# Copy package.json files for all workspace packages
COPY packages/shared/package.json ./packages/shared/
COPY packages/renderers/package.json ./packages/renderers/
COPY apps/web/package.json ./apps/web/

# Install dependencies
RUN pnpm install --frozen-lockfile

# ============================================================================
# Builder stage - Build the application
# ============================================================================
FROM base AS builder

WORKDIR /app

# Copy everything from deps (simpler approach for pnpm workspaces)
COPY --from=deps /app ./

# Copy source code
COPY packages/shared ./packages/shared
COPY packages/renderers ./packages/renderers
COPY apps/web ./apps/web

# Build the web application (skip type checking for faster builds)
WORKDIR /app/apps/web
RUN pnpm astro build

# ============================================================================
# Runtime stage - Minimal production image
# ============================================================================
FROM base AS runtime

WORKDIR /app

# Create non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 astro

# Copy package files for production dependencies
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/renderers/package.json ./packages/renderers/
COPY apps/web/package.json ./apps/web/

# Install all dependencies (React is needed at runtime for SSR)
RUN pnpm install --frozen-lockfile

# Copy built application to the web app directory (for proper module resolution)
COPY --from=builder --chown=astro:nodejs /app/apps/web/dist ./apps/web/dist

# Environment variables
ENV HOST=0.0.0.0
ENV PORT=4321
ENV NODE_ENV=production

# Switch to non-root user
USER astro

# Working directory must be apps/web for proper node_modules resolution
WORKDIR /app/apps/web

EXPOSE 4321

CMD ["node", "./dist/server/entry.mjs"]

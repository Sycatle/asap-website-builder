# ============================================================================
# ASAP v2 - Production Environment Variables
# Copy this file to .env.prod and customize values for your deployment
# ============================================================================

# Database Configuration
POSTGRES_USER=asap
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=asap

# API Configuration
API_PORT=3000
JWT_SECRET=your_jwt_secret_key_min_32_characters_long

# CORS & Frontend Configuration
# ALLOWED_ORIGINS: comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:4322
# FRONTEND_URL: base URL for frontend redirects (OAuth, etc.)
FRONTEND_URL=http://localhost:4321
# TRUSTED_PROXIES: comma-separated list of trusted proxy IPs for rate limiting
# Only these IPs can set X-Forwarded-For headers that will be trusted
TRUSTED_PROXIES=127.0.0.1,::1

# Web Configuration  
WEB_PORT=4321
PUBLIC_API_URL=http://localhost:3000/api

# Sites Configuration
SITES_PORT=4322

# Worker Configuration
WORKER_POLL_INTERVAL=30

# Version Tag
VERSION=latest

# Environment (development/production)
# Used for security features like Secure cookie flag
ENVIRONMENT=production

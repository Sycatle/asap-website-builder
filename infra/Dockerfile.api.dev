# Development Dockerfile for API with hot reload
FROM rustlang/rust:nightly-slim

WORKDIR /app

# Install dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install cargo-watch for hot reload
RUN cargo install cargo-watch

# Copy workspace Cargo files
COPY Cargo.toml Cargo.lock ./
COPY core/shared/Cargo.toml ./core/shared/
COPY core/domain/Cargo.toml ./core/domain/
COPY core/api/Cargo.toml ./core/api/
COPY core/payments/Cargo.toml ./core/payments/
COPY apps/api/Cargo.toml ./apps/api/
COPY apps/worker/Cargo.toml ./apps/worker/
COPY modules/analytics/Cargo.toml ./modules/analytics/
COPY modules/github-generator/Cargo.toml ./modules/github-generator/
COPY modules/projections/Cargo.toml ./modules/projections/
COPY modules/themes/Cargo.toml ./modules/themes/
COPY modules/notifications/Cargo.toml ./modules/notifications/

# Create stub files for dependency caching
RUN mkdir -p core/shared/src && echo "// stub" > core/shared/src/lib.rs && \
    mkdir -p core/domain/src && echo "// stub" > core/domain/src/lib.rs && \
    mkdir -p core/api/src && echo "// stub" > core/api/src/lib.rs && \
    mkdir -p core/payments/src && echo "// stub" > core/payments/src/lib.rs && \
    mkdir -p apps/api/src && echo "fn main() {}" > apps/api/src/main.rs && \
    mkdir -p apps/worker/src && echo "fn main() {}" > apps/worker/src/main.rs && \
    mkdir -p modules/analytics/src && echo "// stub" > modules/analytics/src/lib.rs && \
    mkdir -p modules/github-generator/src && echo "// stub" > modules/github-generator/src/lib.rs && \
    mkdir -p modules/projections/src && echo "// stub" > modules/projections/src/lib.rs && \
    mkdir -p modules/themes/src && echo "// stub" > modules/themes/src/lib.rs && \
    mkdir -p modules/notifications/src && echo "// stub" > modules/notifications/src/lib.rs

# Pre-build dependencies
RUN cargo build --bin asap-api 2>/dev/null || true
RUN rm -rf core apps modules

# Copy all source code (will be overwritten by volume mounts)
COPY core ./core
COPY apps ./apps
COPY modules ./modules
COPY .sqlx ./.sqlx

EXPOSE 3000

# Use cargo-watch for hot reload
CMD ["cargo", "watch", "-x", "run --bin asap-api", "-w", "apps/api", "-w", "core", "-w", "modules"]

# Database connection
DATABASE_URL=postgres://asap:asap_dev_password@localhost:5432/asap

# Server configuration
HOST=0.0.0.0
PORT=3000

# Environment (development | production)
ENVIRONMENT=development

# JWT configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Cookie configuration for cross-domain authentication
# In production, use the parent domain with leading dot for subdomain sharing
COOKIE_DOMAIN=
# Enable secure cookies only in production (HTTPS)
COOKIE_SECURE=false
# Enable cross-site cookies for SSO between subdomains
COOKIE_CROSS_SITE=false

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:4322,http://localhost:4323

# ===========================================
# OAuth Configuration (Optional)
# ===========================================


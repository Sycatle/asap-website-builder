# Database connection
DATABASE_URL=postgres://asap:STRONG_PASSWORD_HERE@db.asap.cool:5432/asap

# Server configuration
HOST=0.0.0.0
PORT=3000

# Environment (development | production)
ENVIRONMENT=production

# JWT configuration - USE A STRONG SECRET IN PRODUCTION
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_256_BIT_SECRET_KEY

# Cookie configuration for cross-domain SSO
# Parent domain with leading dot for subdomain sharing
COOKIE_DOMAIN=.asap.cool
# Enable secure cookies (required for HTTPS)
COOKIE_SECURE=true
# Enable cross-site cookies (SameSite=None) for SSO
COOKIE_CROSS_SITE=true

# CORS allowed origins (production subdomains)
ALLOWED_ORIGINS=https://app.asap.cool,https://accounts.asap.cool,https://asap.cool

# Logging
RUST_LOG=info

# ===========================================
# AI Configuration
# ===========================================

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (optional, for fallback)
ANTHROPIC_API_KEY=

# Redis URL (for rate limiting)
REDIS_URL=redis://redis:6379
